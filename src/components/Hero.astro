---
import HeaderLink from './HeaderLink.astro';

const title = "GirlCode.";
const description = "Realizing all of us are part of GirlCode while working for the same organization we saw an opportunity to collaborate - and the outcome was our GirlCode Coffee Chat.";
---

<div>
  <h2>
		{title.slice(0,-1)}<span class="text-primary-red">{title.at(-1)}</span>
	</h2>
  <p class="py-6">{description}</p>
  <HeaderLink href="/about-us" class="font-bold px-4 py-1 bg-primary-yellow rounded-full">About us</HeaderLink>
</div>
